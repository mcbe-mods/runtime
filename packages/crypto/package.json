{
  "name": "@mcbe-mods/crypto",
  "type": "module",
  "version": "1.0.0-beta.3",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.1",
  "description": "Symmetric encryption for MCBE Script API — XChaCha20-Poly1305 with password/key support",
  "author": "Lete114",
  "license": "MIT",
  "homepage": "https://github.com/mcbe-mods/runtime#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcbe-mods/runtime.git"
  },
  "bugs": "https://github.com/mcbe-mods/runtime/issues",
  "keywords": [
    "minecraft",
    "mcbe",
    "crypto",
    "encryption",
    "xchacha20",
    "poly1305",
    "bedrock",
    "script-api"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepublishOnly": "pnpm build",
    "test": "pnpm run build && vitest"
  },
  "dependencies": {
    "@mcbe-mods/utils": "workspace:^",
    "@noble/ciphers": "catalog:deps",
    "@noble/hashes": "catalog:deps"
  },
  "devDependencies": {
    "tsdown": "catalog:cli",
    "tsdown-stale-guard": "catalog:testing",
    "tsnapi": "catalog:testing",
    "typescript": "catalog:cli",
    "vitest": "catalog:testing"
  },
  "inlinedDependencies": {
    "@noble/ciphers": "2.2.0",
    "@noble/hashes": "2.2.0"
  }
