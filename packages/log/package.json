{
  "name": "@mcbe-mods/log",
  "type": "module",
  "version": "1.0.0-beta.6",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.1",
  "description": "Logging utility for MCBE Script API",
  "author": "Lete114",
  "license": "MIT",
  "homepage": "https://github.com/mcbe-mods/runtime#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcbe-mods/runtime.git"
  },
  "bugs": "https://github.com/mcbe-mods/runtime/issues",
  "keywords": [
    "minecraft",
    "mcbe",
    "log",
    "logging",
    "bedrock"
  ],
  "sideEffects": false,
