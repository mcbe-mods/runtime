{
  "name": "@mcbe-mods/discover",
  "type": "module",
  "version": "0.0.0",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.1",
  "description": "Service discovery for MCBE Script API — heartbeat-based in-world registry",
  "author": "Lete114",
  "license": "MIT",
  "homepage": "https://github.com/mcbe-mods/runtime#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcbe-mods/runtime.git"
  },
  "bugs": "https://github.com/mcbe-mods/runtime/issues",
  "keywords": [
    "minecraft",
    "mcbe",
    "discover",
    "discovery",
    "mdns",
    "bedrock",
    "script-api"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepublishOnly": "pnpm build",
    "test": "pnpm run build && vitest"
  },
  "peerDependencies": {
    "@minecraft/server": ">=1.18.0"
  },
  "dependencies": {
    "@mcbe-mods/bedrock-url": "workspace:^",
    "@mcbe-mods/log": "workspace:^",
    "@mcbe-mods/protocol": "workspace:^"
  },
  "devDependencies": {
    "@minecraft/server": "catalog:",
    "tsdown": "catalog:cli",
    "typescript": "catalog:cli",
    "vitest": "catalog:testing"
  }
}
