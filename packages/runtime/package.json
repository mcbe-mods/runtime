{
  "name": "@mcbe-mods/runtime",
  "type": "module",
  "version": "1.0.0-beta.3",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.1",
  "description": "Unified entry point for MCBE Script API runtime",
  "author": "Lete114",
  "license": "MIT",
  "homepage": "https://github.com/mcbe-mods/runtime#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcbe-mods/runtime.git"
  },
  "bugs": "https://github.com/mcbe-mods/runtime/issues",
  "keywords": [
    "minecraft",
    "mcbe",
    "runtime",
    "script-api",
    "bedrock"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepublishOnly": "pnpm build",
    "test": "pnpm run build && vitest"
  },
  "peerDependencies": {
    "@minecraft/server": ">=1.18.0"
  },
  "dependencies": {
    "@mcbe-mods/bedrock-url": "workspace:^",
    "@mcbe-mods/discover": "workspace:^",
    "@mcbe-mods/ipc": "workspace:^",
    "@mcbe-mods/log": "workspace:^",
    "@mcbe-mods/protocol": "workspace:^",
    "@mcbe-mods/rpc": "workspace:^",
    "@mcbe-mods/utils": "workspace:^"
  },
  "devDependencies": {
    "@minecraft/server": "catalog:deps",
    "tsdown": "catalog:cli",
    "typescript": "catalog:cli",
    "vitest": "catalog:testing"
  }
}
