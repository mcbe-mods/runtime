{
  "name": "@mcbe-mods/ipc",
  "type": "module",
  "version": "1.0.0-beta.5",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.1",
  "description": "Inter-Pack Communication system for MCBE Script API",
  "author": "Lete114",
  "license": "MIT",
  "homepage": "https://github.com/mcbe-mods/runtime#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcbe-mods/runtime.git"
  },
  "bugs": "https://github.com/mcbe-mods/runtime/issues",
  "keywords": [
    "minecraft",
    "mcbe",
    "ipc",
    "script-api",
    "bedrock"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "tsdown -F .",
    "dev": "tsdown -F . --watch",
    "prepublishOnly": "pnpm build",
    "test": "vitest",
    "bench": "vitest bench"
  },
  "peerDependencies": {
    "@minecraft/server": ">=1.18.0"
  },
  "dependencies": {
    "@mcbe-mods/bedrock-url": "workspace:^",
    "@mcbe-mods/protocol": "workspace:^",
    "@mcbe-mods/utils": "workspace:^",
    "mini-emit": "catalog:deps"
  },
  "devDependencies": {
    "@mcbe-mods/compress": "workspace:^",
    "@minecraft/server": "catalog:deps",
    "tsdown": "catalog:cli",
    "tsnapi": "catalog:testing",
    "typescript": "catalog:cli",
    "vitest": "catalog:testing"
  }
}
