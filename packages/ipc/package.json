{
  "name": "@mcbe-mods/ipc",
  "type": "module",
  "version": "0.0.1-beta.5",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.1",
  "description": "Inter-Pack Communication system for MCBE Script API",
  "author": "Lete114",
  "license": "MIT",
  "homepage": "https://github.com/mcbe-mods/ipc#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcbe-mods/ipc.git"
  },
  "bugs": "https://github.com/mcbe-mods/ipc/issues",
  "keywords": [
    "minecraft",
    "mcbe",
    "ipc",
    "script-api",
    "bedrock"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint",
    "prepublishOnly": "nr build",
    "release": "bumpp",
    "start": "tsx src/index.ts",
    "test": "pnpm run build && vitest",
    "bench": "vitest bench",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "@minecraft/server": ">=1.18.0"
  },
  "dependencies": {
    "@mcbe-mods/bedrock-url": "workspace:^",
    "@mcbe-mods/log": "workspace:^",
    "@mcbe-mods/protocol": "workspace:^",
    "lz-string": "catalog:deps",
    "mini-emit": "catalog:deps"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:cli",
    "@antfu/ni": "catalog:cli",
    "@antfu/utils": "catalog:inlined",
    "@minecraft/server": "catalog:",
    "@types/lz-string": "catalog:types",
    "@types/node": "catalog:types",
    "bumpp": "catalog:cli",
    "eslint": "catalog:cli",
    "lint-staged": "catalog:cli",
    "publint": "catalog:cli",
    "simple-git-hooks": "catalog:cli",
    "tsdown": "catalog:cli",
    "tsdown-stale-guard": "catalog:testing",
    "tsnapi": "catalog:testing",
    "tsx": "catalog:cli",
    "typescript": "catalog:cli",
    "vite": "catalog:cli",
    "vitest": "catalog:testing"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && pnpm run build && npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "inlinedDependencies": {
    "lz-string": "1.5.0",
    "mini-emit": "1.0.0-beta.0"
  }
}
