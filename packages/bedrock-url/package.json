{
  "name": "@mcbe-mods/bedrock-url",
  "type": "module",
  "version": "1.0.0-beta.1",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.1",
  "description": "Bedrock URI parser for MCBE Script API",
  "author": "Lete114",
  "license": "MIT",
  "homepage": "https://github.com/mcbe-mods/runtime#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcbe-mods/runtime.git"
  },
  "bugs": "https://github.com/mcbe-mods/runtime/issues",
  "keywords": [
    "minecraft",
    "mcbe",
    "bedrock-url",
    "uri",
    "bedrock"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepublishOnly": "pnpm build",
    "test": "pnpm run build && vitest"
  },
  "devDependencies": {
    "tsdown": "catalog:cli",
    "typescript": "catalog:cli",
    "vitest": "catalog:testing"
  }
}
